generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  passwordHash String
  isAdmin      Boolean        @default(false)
  createdAt    DateTime       @default(now())
  registrations Registration[]
  memePosts    MemePost[]
  chatMessages ChatMessage[]
}

model Tournament {
  id           String         @id @default(cuid())
  slug         String         @unique
  title        String
  description  String
  startsAt     DateTime
  endsAt       DateTime?
  rules        String          @default("Keep it funny, keep it original, and do not summon the group chat lawyers.") @db.Text
  winnerPostId String?
  entryFeePaise Int           @default(0)
  maxPlayers   Int            @default(64)
  status       TournamentStatus @default(UPCOMING)
  createdAt    DateTime       @default(now())
  registrations Registration[]
  memePosts    MemePost[]
  chatMessages ChatMessage[]
  pollVotes    PollVote[]
}

model Registration {
  id           String         @id @default(cuid())
  userId       String
  tournamentId String
  status       RegistrationStatus @default(PENDING_PAYMENT)
  createdAt    DateTime       @default(now())
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament   Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  payment      Payment?
  @@unique([userId, tournamentId])
  @@index([tournamentId, status])
}

model Payment {
  id                String        @id @default(cuid())
  registrationId    String        @unique
  provider          String        @default("razorpay")
  orderId           String        @unique
  paymentId         String?
  signature         String?
  amountPaise       Int
  status            PaymentStatus @default(CREATED)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  registration      Registration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

enum TournamentStatus {
  UPCOMING
  LIVE
  COMPLETED
}

enum RegistrationStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
}

model MemePost {
  id           String          @id @default(cuid())
  tournamentId String
  authorId     String
  imageData    String          @db.Text
  caption      String          @db.VarChar(280)
  createdAt    DateTime        @default(now())
  hidden       Boolean         @default(false)
  tournament   Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  author       User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions    MemeReaction[]
  votes        PollVote[]
  reports      MemeReport[]
  @@index([tournamentId, createdAt])
}

model MemeReaction {
  id          String   @id @default(cuid())
  postId      String
  visitorKey  String
  kind        String   @default("😂")
  createdAt   DateTime @default(now())
  post        MemePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@index([postId, kind])
  @@unique([postId, visitorKey, kind])
}

model PollVote {
  id           String     @id @default(cuid())
  tournamentId String
  postId       String
  voterKey     String
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  post         MemePost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@unique([tournamentId, voterKey])
  @@index([postId])
}

model ChatMessage {
  id           String          @id @default(cuid())
  tournamentId String
  userId       String?
  displayName  String          @db.VarChar(60)
  body         String          @db.VarChar(500)
  createdAt    DateTime        @default(now())
  hidden       Boolean         @default(false)
  tournament   Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  reactions    ChatReaction[]
  reports      ChatReport[]
  @@index([tournamentId, createdAt])
}

model ChatReaction {
  id            String      @id @default(cuid())
  messageId     String
  visitorKey    String
  kind          String      @default("😂")
  createdAt     DateTime    @default(now())
  message       ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  @@index([messageId, kind])
  @@unique([messageId, visitorKey, kind])
}

model MemeReport {
  id          String       @id @default(cuid())
  postId      String
  reporterKey String
  reason      String       @db.VarChar(240)
  status      ReportStatus @default(OPEN)
  createdAt   DateTime     @default(now())
  post        MemePost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@unique([postId, reporterKey])
  @@index([status, createdAt])
}

model ChatReport {
  id          String       @id @default(cuid())
  messageId   String
  reporterKey String
  reason      String       @db.VarChar(240)
  status      ReportStatus @default(OPEN)
  createdAt   DateTime     @default(now())
  message     ChatMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  @@unique([messageId, reporterKey])
  @@index([status, createdAt])
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}
